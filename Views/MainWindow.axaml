<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
        x:Class="framenion.MainWindow"
        xmlns:local="clr-namespace:framenion"
        xmlns:src="clr-namespace:framenion.Src"
        Title="Framenion - A Warframe companion app"
        Width="1280" Height="720">

    <Grid RowDefinitions="Auto,*">
        <!-- Top Bar -->
        <Border Grid.Row="0" Background="#2C2C2C" Padding="10">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Menu Buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                    <Button Name="ItemsButton"
                            Content="Equipment"
                            Click="OnItemsClick"
                            Classes="menuButton selected"
                            Padding="20,10"/>
                    <Button Name="InventoryButton"
                            Content="Relics"
                            Click="OnInventoryClick"
                            Classes="menuButton"
                            Padding="20,10"/>
                </StackPanel>

                <!-- Player Info Panel -->
                <Border Grid.Column="2"
                        Background="#1E1E1E"
                        CornerRadius="5"
                        Padding="15,5">
                    <StackPanel Orientation="Horizontal" Spacing="15">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <Button Name="RefreshInfoButton"
                                Content="↻"
                                Click="OnRefreshInfoClickAsync"
                                Classes="filterButton"
                                Padding="10,6"
                                FontSize="14"
                                ToolTip.Tip="Refresh Inventory Info"/>
                            <Image Name="PlayerIcon"
                                   Source=""
                                   Width="32" Height="32"
                                   VerticalAlignment="Center"/>
                            <Image Name="MasteryIcon"
                                   Source=""
                                   Width="32" Height="32"
                                   VerticalAlignment="Center"/>
                            <TextBlock Name="MasteryText"
                                       Text=""
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock Name="PlayerName"
                                       Text=""
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <Image Source="avares://framenion/assets/credits.png"
                                   Width="24" Height="24"
                                   VerticalAlignment="Center"/>
                            <TextBlock Name="CreditsText"
                                       Text=""
                                       VerticalAlignment="Center"
                                       Foreground="#B4B4BE"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <Image Source="avares://framenion/assets/platinum.png"
                                   Width="24" Height="24"
                                   VerticalAlignment="Center"/>
                            <TextBlock Name="PlatinumText"
                                       Text=""
                                       VerticalAlignment="Center"
                                       Foreground="#B4B4BE"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Content Area: Left = tabs, Right = Void Fissures panel -->
        <Grid Grid.Row="1" Background="#1A1A1A" ColumnDefinitions="*,300">

            <!-- ─── LEFT: Tab Content ─── -->
            <Grid Grid.Column="0">
                <!-- Items Content -->
                <Border Name="ItemsContent" IsVisible="True" Padding="20">
                    <Grid RowDefinitions="Auto,Auto,*">
                        <Grid Grid.Row="0" ColumnDefinitions="*,300" Margin="0,0,0,20">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Name="FilterAllButton"
                                    Click="OnFilterClick"
                                    Tag="All"
                                    Classes="filterButton selected"
                                    Padding="8,8"
                                    ToolTip.Tip="All">
                                <Image Source="avares://framenion/assets/all.png"
                                       Width="24" Height="24"
                                       VerticalAlignment="Center"/>
                                </Button>
                            <Button Name="FilterWarframesButton"
                                    Click="OnFilterClick"
                                    Tag="Warframes"
                                    Classes="filterButton"
                                    Padding="8,8"
                                    ToolTip.Tip="Warframe">
                             <Image Source="avares://framenion/assets/warframes.png"
                                   Width="24" Height="24"
                                   VerticalAlignment="Center"/>
                            </Button>
                            <Button Name="FilterPrimaryButton"
                                    Click="OnFilterClick"
                                    Tag="Primary"
                                    Classes="filterButton"
                                    Padding="8,8"
                                    ToolTip.Tip="Primary">
                                <Image Source="avares://framenion/assets/primary.png"
                                       Width="24" Height="24"
                                   VerticalAlignment="Center"/>
                            </Button>
                            <Button Name="FilterSecondaryButton"
                                    Click="OnFilterClick"
                                    Tag="Secondary"
                                    Classes="filterButton"
                                    Padding="8,8"
                                    ToolTip.Tip="Secondary">
                                <Image Source="avares://framenion/assets/pistols.png"
                                       Width="24" Height="24"
                                       VerticalAlignment="Center"/>
                                </Button>
                            <Button Name="FilterMeleeButton"
                                    Click="OnFilterClick"
                                    Tag="Melee"
                                    Classes="filterButton"
                                    Padding="8,8"
                                    ToolTip.Tip="Melee">
                                <Image Source="avares://framenion/assets/melee.png"
                                       Width="24" Height="24"
                                       VerticalAlignment="Center"/>
                                </Button>
                            <Button Name="FilterArchgunsButton"
                                    Click="OnFilterClick"
                                    Tag="Archguns"
                                    Classes="filterButton"
                                    Padding="8,8"
                                    ToolTip.Tip="Archgun">
                                <Image Source="avares://framenion/assets/archguns.png"
                                       Width="24" Height="24"
                                       VerticalAlignment="Center"/>
                                </Button>
                            <Button Name="FilterArchmeleeButton"
                                    Click="OnFilterClick"
                                    Tag="Archmelee"
                                    Classes="filterButton"
                                    Padding="8,8"
                                    ToolTip.Tip="Archmelee">
                                <Image Source="avares://framenion/assets/archmelees.png"
                                       Width="24" Height="24"
                                       VerticalAlignment="Center"/>
                                </Button>
                            <Button Name="FilterCompanionsButton"
                                    Click="OnFilterClick"
                                    Tag="Companions"
                                    Classes="filterButton"
                                    Padding="8,8"
                                    ToolTip.Tip="Companion">
                                <Image Source="avares://framenion/assets/sentinels.png"
                                       Width="24" Height="24"
                                       VerticalAlignment="Center"/>
                                </Button>
                            <Button Name="FilterVehiclesButton"
                                    Click="OnFilterClick"
                                    Tag="Vehicles"
                                    Classes="filterButton"
                                    Padding="8,8"
                                    ToolTip.Tip="Vehicle">
                                <Image Source="avares://framenion/assets/archwings.png"
                                       Width="24" Height="24"
                                       VerticalAlignment="Center"/>
                            </Button>
                            <Button Name="FilterAmpsButton"
                                    Click="OnFilterClick"
                                    Tag="Amps"
                                    Classes="filterButton"
                                    Padding="8,8"
                                    ToolTip.Tip="Amp">
                                <Image Source="avares://framenion/assets/amps.png"
                                       Width="24" Height="24"
                                       VerticalAlignment="Center"/>
                                </Button>
                        </StackPanel>
                            <TextBox Grid.Column="1"
                                     Name="ItemsSearchBox"
                                     Watermark="Search items..."
                                     Padding="8,8"
                                     TextChanged="OnSearchTextChanged"
                                     Background="#2C2C2C"
                                     Foreground="White"
                                     BorderBrush="#4A4A4A"
                                     BorderThickness="1"
                                     CornerRadius="4"/>
                        </Grid>
                        <Border Grid.Row="2"
                                Background="#2C2C2C"
                                CornerRadius="8"
                                BorderBrush="#4A4A4A"
                                BorderThickness="1">
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                <ItemsRepeater Name="ItemsList">
                                    <ItemsRepeater.Layout>
                                        <WrapLayout Orientation="Horizontal"/>
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="src:Item">
                                            <Border Background="#1E1E1E"
                                                    CornerRadius="6"
                                                    Margin="8"
                                                    Padding="12"
                                                    Width="200"
                                                    MinHeight="220"
                                                    BorderBrush="{Binding BorderColor}"
                                                    BorderThickness="2">
                                                <Border.Styles>
                                                    <Style Selector="Border:pointerover">
                                                        <Setter Property="Background" Value="#2A2A2A"/>
                                                        <Setter Property="BorderBrush" Value="#4A9EFF"/>
                                                    </Style>
                                                </Border.Styles>
                                                <Grid RowDefinitions="Auto,Auto,Auto,*">
                                                    <!-- Main Icon -->
                                                    <Border Grid.Row="0"
                                                            Width="72" Height="72"
                                                            HorizontalAlignment="Center"
                                                            Background="#252525"
                                                            CornerRadius="4"
                                                            Margin="0,0,0,8"
                                                            BorderBrush="#4A4A4A"
                                                            BorderThickness="1">
                                                        <Image Source="{Binding Icon}"
                                                               Stretch="Uniform"
                                                               Width="70" Height="70"/>
                                                    </Border>
                                                    <!-- Name + Mastery -->
                                                    <StackPanel Grid.Row="1"
                                                                Orientation="Horizontal"
                                                                Spacing="6"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Margin="0,0,0,8">
                                                        <TextBlock Text="{Binding Name}"
                                                                   Foreground="White"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   TextWrapping="Wrap"
                                                                   TextAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   MaxWidth="140"/>
                                                        <Image Name="mastery_icon"
                                                               Source="avares://framenion/assets/mastered.png"
                                                               Stretch="Uniform"
                                                               Width="20" Height="20"
                                                               IsVisible="{Binding Mastered}"
                                                               VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <!-- Ingredients -->
                                                    <ItemsControl Grid.Row="2" ItemsSource="{Binding Ingredients}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="src:RecipeIngredient">
                                                                <Border Width="46" Height="46"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"
                                                                        Background="{Binding BackgroundColor}"
                                                                        CornerRadius="4"
                                                                        Margin="4"
                                                                        BorderBrush="{Binding BorderColor}"
                                                                        BorderThickness="1">
                                                                    <Border.Styles>
                                                                        <Style Selector="Border:pointerover">
                                                                            <Setter Property="Background" Value="#252525"/>
                                                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                                                        </Style>
                                                                    </Border.Styles>
                                                                    <Grid>
                                                                        <Image Source="{Binding Icon}"
                                                                               Stretch="Uniform"
                                                                               Width="40" Height="40"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"
                                                                               ToolTip.Tip="{Binding CountName}"/>
                                                                        <TextBlock Text="{Binding OwnedCount}"
                                                                                   Foreground="White"
                                                                                   FontSize="10"
                                                                                   FontWeight="Bold"
                                                                                   HorizontalAlignment="Right"
                                                                                   VerticalAlignment="Bottom"
                                                                                   Background="#80000000"
                                                                                   Padding="2,0"
                                                                                   IsVisible="{Binding IsCountVisible}"/>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>

            </Grid>

            <!-- ─── RIGHT: Void Fissures Panel (always visible) ─── -->
            <Border Grid.Column="1"
                    Background="#1E1E1E"
                    BorderBrush="#3A3A3A"
                    BorderThickness="1,0,0,0"
                    Padding="12">
                <Grid RowDefinitions="Auto,Auto,*">

                    <!-- Title and Refresh -->
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto, Auto" Margin="0,0,0,12">
                        <TextBlock Grid.Column="0" Text="Void Fissures"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Name="FilterListButton"
                                Click="OnFilterListClick"
                                Padding="10,6"
                                Margin="0,0,5,0"
                                Classes="filterButton"
                                ToolTip.Tip="Fissure Alert Settings">
                            <Image Source="avares://framenion/assets/filter.png"
                                       Width="15" Height="17"
                                       VerticalAlignment="Center"/>
                            </Button>
                        <Button Grid.Column="2"
                                Name="RefreshFissuresButton"
                                Content="↻"
                                Click="OnRefreshFissuresClick"
                                Padding="10,6"
                                Classes="filterButton"
                                FontSize="14"
                                ToolTip.Tip="Refresh fissures list"/>
                    </Grid>

                    <!-- Filter Buttons -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6" Margin="0,0,0,12">
                        <Button Name="FissureFilterNormalButton"
                                Content="Normal"
                                Click="OnFissureFilterClick"
                                Tag="Normal"
                                Classes="filterButton selected"
                                Padding="12,6"/>
                        <Button Name="FissureFilterSteelPathButton"
                                Content="Steel Path"
                                Click="OnFissureFilterClick"
                                Tag="SteelPath"
                                Classes="filterButton"
                                Padding="12,6"/>
                    </StackPanel>

                    <!-- Fissures List -->
                    <ScrollViewer Grid.Row="2"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl Name="FissuresList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="src:VoidFissure">
                                    <Border Background="{Binding RowBackground}"
                                            BorderBrush="{Binding RowBorderBrush}"
                                            BorderThickness="{Binding RowBorderThickness}"
                                            CornerRadius="6"
                                            Margin="0,0,0,6"
                                            Padding="10">
                                        <Border.Styles>
                                        </Border.Styles>
                                        <Grid RowDefinitions="Auto,Auto,Auto">
                                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                                                <TextBlock Text="{Binding Tier}"
                                                           Classes="TierText"
                                                           Foreground="{Binding Color}"
                                                           FontSize="12"
                                                           FontWeight="Bold"
                                                           VerticalAlignment="Center"/>
                                                <Border Grid.Column="1"
                                                        Background="#3A3A3A"
                                                        CornerRadius="4"
                                                        Padding="6,3">
                                                    <TextBlock Text="{Binding TimeRemaining}"
                                                               Foreground="#4A9EFF"
                                                               FontSize="12"
                                                               FontWeight="Bold"/>
                                                </Border>
                                            </Grid>
                                            <TextBlock Grid.Row="1"
                                                       Foreground="White"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,3">
                                                <Run Text="{Binding MissionType}"/>
                                                <Run Text="{Binding LevelRange}"/>
                                                <Run Text="-"/>
                                                <Run Text="{Binding Faction}"/>
                                            </TextBlock>
                                            <TextBlock Grid.Row="2"
                                                       Text="{Binding Location}"
                                                       Foreground="#888888"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>

    <Window.Styles>
        <Style Selector="Button.menuButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="BorderThickness" Value="0,0,0,3"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.menuButton:pointerover">
            <Setter Property="Foreground" Value="#CCCCCC"/>
        </Style>
        <Style Selector="Button.menuButton.selected">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#4A9EFF"/>
        </Style>
        <Style Selector="Button.filterButton">
            <Setter Property="Background" Value="#2C2C2C"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#4A4A4A"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.filterButton:pointerover">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
        </Style>
        <Style Selector="Button.filterButton.selected">
            <Setter Property="Background" Value="#4A9EFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#4A9EFF"/>
        </Style>
    </Window.Styles>
</Window>
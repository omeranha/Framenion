<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
        x:Class="framenion.MainWindow"
        xmlns:local="clr-namespace:framenion"
        xmlns:src="clr-namespace:framenion.Src"
        x:Name="RootWindow"
        Title="Framenion - A Warframe companion app"
        Width="1280" Height="720">

    <Grid RowDefinitions="Auto,*">
        <!-- Top Bar -->
        <Border Grid.Row="0" Background="{DynamicResource PanelBackgroundBrush}" Padding="10">
            <Grid ColumnDefinitions="Auto, *, Auto, Auto, Auto">
                <!-- Menu Buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                    <Button Name="ItemsButton" Content="Equipment" Classes="selected" Click="OnItemsClick" Padding="20,10"/>
                    <Button Name="InventoryButton" Content="Relics" Click="OnInventoryClick" Padding="20,10"/>
                </StackPanel>

                <!-- Player Info Panel -->
                <ProgressBar Grid.Column="2" MinWidth="100" Name="LoadingBar" IsIndeterminate="true" IsVisible="{Binding #RootWindow.IsLoading}" ToolTip.Tip="Initializing..."
             Height="10" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="Green" Margin="0, 0, 10, 0"/>
                <Image Grid.Column="3" Name="WarframeOpened" HorizontalAlignment="Right" Width="32" Height="32" VerticalAlignment="Center" ToolTip.Tip="Warframe is closed" Source="avares://framenion/assets/uncheck_d.png" Margin="0, 0, 10, 0"/>
                <Border Grid.Column="4" Background="{DynamicResource SurfaceBackgroundBrush}" CornerRadius="5" Padding="15,5" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal" Spacing="15">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <Button Name="RefreshInfoButton" Content="↻" Click="OnRefreshInfoClickAsync" Classes="iconButton" ToolTip.Tip="Refresh Inventory Info"/>

                            <Image Name="PlayerIcon" Width="32" Height="32" VerticalAlignment="Center"/>
                            <Image Name="MasteryIcon" Width="32" Height="32" VerticalAlignment="Center"/>

                            <TextBlock Name="MasteryText" VerticalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource PrimaryForegroundBrush}"/>

                            <TextBlock Name="PlayerName" VerticalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource PrimaryForegroundBrush}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <Image Source="avares://framenion/assets/credits.png" Width="24" Height="24" VerticalAlignment="Center"/>
                            <TextBlock Name="CreditsText" Text="" VerticalAlignment="Center" Foreground="{DynamicResource MutedForegroundBrush}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <Image Source="avares://framenion/assets/platinum.png" Width="24" Height="24" VerticalAlignment="Center"/>
                            <TextBlock Name="PlatinumText" VerticalAlignment="Center" Foreground="{DynamicResource MutedForegroundBrush}"/>
                        </StackPanel>

                        <Button Content="⚙" Click="OnOpenSettingsClick" Classes="iconButton" ToolTip.Tip="Settings"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Content Area: Left = tabs, Right = Void Fissures panel -->
        <Grid Grid.Row="1" Background="{DynamicResource AppBackgroundBrush}" ColumnDefinitions="*,300">

            <!-- ─── LEFT: Tab Content ─── -->
            <Grid Grid.Column="0">
                <!-- Items Content -->
                <Border Name="ItemsContent" IsVisible="True" Padding="20">
                    <Grid RowDefinitions="Auto,Auto,*">
                        <Grid Grid.Row="0" ColumnDefinitions="*,40,40,40,200" Margin="0,0,0,20">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button Name="FilterAllButton" Click="OnFilterClick"
                                        Tag="All"
                                        Classes="selected"
                                        Padding="8,8"
                                        ToolTip.Tip="All">
                                    <Image Source="avares://framenion/assets/all.png" Width="24" Height="24" VerticalAlignment="Center"/>
                                </Button>

                                <Button Name="FilterWarframesButton"
                                        Click="OnFilterClick"
                                        Tag="Warframes"
                                        Padding="8,8"
                                        ToolTip.Tip="Warframe">
                                    <Image Source="avares://framenion/assets/warframes.png" Width="24" Height="24" VerticalAlignment="Center"/>
                                </Button>

                                <Button Name="FilterPrimaryButton"
                                        Click="OnFilterClick"
                                        Tag="Primary"
                                        Padding="8,8"
                                        ToolTip.Tip="Primary">
                                    <Image Source="avares://framenion/assets/primary.png" Width="24" Height="24" VerticalAlignment="Center"/>
                                </Button>

                                <Button Name="FilterSecondaryButton"
                                        Click="OnFilterClick"
                                        Tag="Secondary"
                                        Padding="8,8"
                                        ToolTip.Tip="Secondary">
                                    <Image Source="avares://framenion/assets/pistols.png" Width="24" Height="24" VerticalAlignment="Center"/>
                                </Button>

                                <Button Name="FilterMeleeButton"
                                        Click="OnFilterClick"
                                        Tag="Melee"
                                        Padding="8,8"
                                        ToolTip.Tip="Melee">
                                    <Image Source="avares://framenion/assets/melee.png" Width="24" Height="24" VerticalAlignment="Center"/>
                                </Button>

                                <Button Name="FilterArchgunsButton"
                                        Click="OnFilterClick"
                                        Tag="Archguns"
                                        Padding="8,8"
                                        ToolTip.Tip="Archgun">
                                    <Image Source="avares://framenion/assets/archguns.png" Width="24" Height="24" VerticalAlignment="Center"/>
                                </Button>

                                <Button Name="FilterArchmeleeButton"
                                        Click="OnFilterClick"
                                        Tag="Archmelee"
                                        Padding="8,8"
                                        ToolTip.Tip="Archmelee">
                                    <Image Source="avares://framenion/assets/archmelees.png" Width="24" Height="24" VerticalAlignment="Center"/>
                                </Button>

                                <Button Name="FilterCompanionsButton"
                                        Click="OnFilterClick"
                                        Tag="Companions"
                                        Padding="8,8"
                                        ToolTip.Tip="Companion">
                                    <Image Source="avares://framenion/assets/sentinels.png" Width="24" Height="24" VerticalAlignment="Center"/>
                                </Button>

                                <Button Name="FilterVehiclesButton"
                                        Click="OnFilterClick"
                                        Tag="Vehicles"
                                        Padding="8,8"
                                        ToolTip.Tip="Vehicle">
                                    <Image Source="avares://framenion/assets/archwings.png" Width="24" Height="24" VerticalAlignment="Center"/>
                                </Button>

                                <Button Name="FilterAmpsButton"
                                        Click="OnFilterClick"
                                        Tag="Amps"
                                        Padding="8,8"
                                        ToolTip.Tip="Amp">
                                    <Image Source="avares://framenion/assets/amps.png" Width="24" Height="24" VerticalAlignment="Center"/>
                                </Button>
                            </StackPanel>

                            <Button Grid.Column="1"
                Content="−"
                Click="OnItemsZoomOutClick"
                Classes="iconButton"
                ToolTip.Tip="Zoom out"
                Padding="10,6"/>

        <Button Grid.Column="2"
                Content="%"
                Click="OnItemsZoomResetClick"
                Classes="iconButton"
                ToolTip.Tip="Reset zoom"
                Padding="10,6"/>

        <Button Grid.Column="3"
                Content="+"
                Click="OnItemsZoomInClick"
                Classes="iconButton"
                ToolTip.Tip="Zoom in"
                Padding="10,6"/>

                            <TextBox Grid.Column="4"
                                     Name="ItemsSearchBox"
                                     Watermark="Search items..."
                                     Padding="8,8"
                                     TextChanged="OnSearchTextChanged"
                                     Background="{DynamicResource PanelBackgroundBrush}"
                                     Foreground="{DynamicResource PrimaryForegroundBrush}"
                                     BorderBrush="{DynamicResource ControlBorderBrush}"
                                     BorderThickness="1"
                                     CornerRadius="4"/>
                        </Grid>

                        <Border Grid.Row="2"
                                Background="{DynamicResource PanelBackgroundBrush}"
                                CornerRadius="8"
                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                BorderThickness="1">

                            <ScrollViewer Name="ItemsScrollViewer"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                <ItemsRepeater Name="ItemsList">
                                    <ItemsRepeater.Layout>
                                        <WrapLayout Orientation="Horizontal"/>
                                    </ItemsRepeater.Layout>

                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="src:Item">
                                            <Border Background="{DynamicResource SurfaceBackgroundBrush}"
                                                    CornerRadius="6"
                                                    Margin="8"
                                                    Padding="12"
                                                    Width="{Binding #RootWindow.ItemsTileWidth}"
                                                    MinHeight="{Binding #RootWindow.ItemsTileMinHeight}"
                                                    BorderBrush="{Binding BorderColor}"
                                                    BorderThickness="2">

                                                <Grid RowDefinitions="Auto,Auto,Auto,*">
                                                    <!-- Main Icon -->
                                                    <Border Grid.Row="0"
                                                            Width="72" Height="72"
                                                            HorizontalAlignment="Center"
                                                            Background="{DynamicResource AppBackgroundBrush}"
                                                            CornerRadius="4"
                                                            Margin="0,0,0,8"
                                                            BorderBrush="{DynamicResource ControlBorderBrush}"
                                                            BorderThickness="1">
                                                        <Image Source="{Binding Icon}" Stretch="Uniform" Width="70" Height="70"/>
                                                    </Border>

                                                    <!-- Name + Mastery -->
                                                    <StackPanel Grid.Row="1"
                                                                Orientation="Horizontal"
                                                                Spacing="6"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Margin="0,0,0,8">
                                                        <TextBlock Text="{Binding Name}"
                                                                   Foreground="{DynamicResource PrimaryForegroundBrush}"
                                                                   FontWeight="SemiBold"
                                                                   TextWrapping="Wrap"
                                                                   TextAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   MaxWidth="140"/>

                                                        <Image Name="mastery_icon"
                                                               Source="avares://framenion/assets/mastered.png"
                                                               Stretch="Uniform"
                                                               Width="20" Height="20"
                                                               IsVisible="{Binding Mastered}"
                                                               VerticalAlignment="Center"/>
                                                    </StackPanel>

                                                    <!-- Ingredients -->
                                                    <ItemsControl Grid.Row="2" ItemsSource="{Binding Ingredients}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel Orientation="Horizontal"
                                                                           HorizontalAlignment="Center"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>

                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="src:RecipeIngredient">
                                                                <Border Width="46" Height="46"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"
                                                                        Background="{Binding BackgroundColor}"
                                                                        CornerRadius="4"
                                                                        Margin="4"
                                                                        BorderBrush="{Binding BorderColor}"
                                                                        BorderThickness="1">
                                                                    <Border.Styles>
                                                                        <Style Selector="Border:pointerover">
                                                                            <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}"/>
                                                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                                                        </Style>
                                                                    </Border.Styles>

                                                                    <Grid>
                                                                        <Image Source="{Binding Icon}"
                                                                               Stretch="Uniform"
                                                                               Width="40" Height="40"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"
                                                                               ToolTip.Tip="{Binding CountName}"/>

                                                                        <TextBlock Text="{Binding OwnedCount}"
                                                                                   Foreground="{DynamicResource PrimaryForegroundBrush}"
                                                                                   FontSize="10"
                                                                                   FontWeight="Bold"
                                                                                   HorizontalAlignment="Right"
                                                                                   VerticalAlignment="Bottom"
                                                                                   Background="#80000000"
                                                                                   Padding="2,0"
                                                                                   IsVisible="{Binding IsCountVisible}"/>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- ─── RIGHT: Void Fissures Panel (always visible) ─── -->
            <Border Grid.Column="1" Background="{DynamicResource SurfaceBackgroundBrush}" BorderBrush="{DynamicResource SeparatorBorderBrush}" BorderThickness="1,0,0,0" Padding="12">
                <Grid RowDefinitions="Auto,Auto,*">
                    <!-- Title and Refresh -->
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,12">
                        <TextBlock Grid.Column="0" Text="Void Fissures" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource PrimaryForegroundBrush}" VerticalAlignment="Center"/>

                        <Button Grid.Column="1" Name="FilterListButton" Click="OnFilterListClick" Classes="iconButton" Margin="0,0,5,0" ToolTip.Tip="Fissure Alert Settings">
                            <Image Source="avares://framenion/assets/filter.png" VerticalAlignment="Center"/>
                        </Button>

                        <Button Grid.Column="2" Name="RefreshFissuresButton" Content="↻" Click="OnRefreshFissuresClick" Classes="iconButton" ToolTip.Tip="Refresh fissures list"/>
                    </Grid>

                    <!-- Filter Buttons -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6" Margin="0,0,0,12">
                        <Button Name="FissureFilterNormalButton" Content="Normal" Click="OnFissureFilterClick" Tag="Normal" Classes="selected" Padding="12,6"/>
                        <Button Name="FissureFilterSteelPathButton" Content="Steel Path" Click="OnFissureFilterClick" Tag="SteelPath" Padding="12,6"/>
                    </StackPanel>

                    <!-- Fissures List -->
                    <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <ItemsControl Name="FissuresList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="src:VoidFissure">
                                    <Border Background="{Binding RowBackground}"
                                            BorderBrush="{Binding RowBorderBrush}"
                                            BorderThickness="{Binding RowBorderThickness}"
                                            CornerRadius="6"
                                            Margin="0,0,0,6"
                                            Padding="10">
                                        <Grid RowDefinitions="Auto,Auto,Auto">
                                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                                                <TextBlock Text="{Binding Tier}"
                                                           Classes="TierText"
                                                           Foreground="{Binding Color}"
                                                           FontSize="12"
                                                           FontWeight="Bold"
                                                           VerticalAlignment="Center"/>

                                                <Border Grid.Column="1"
                                                        Background="{DynamicResource ButtonHoverBackgroundBrush}"
                                                        CornerRadius="4"
                                                        Padding="6,3">
                                                    <TextBlock Text="{Binding TimeRemaining}" Foreground="{DynamicResource AccentBrush}" FontSize="12" FontWeight="Bold"/>
                                                </Border>
                                            </Grid>

                                            <TextBlock Grid.Row="1" Foreground="{DynamicResource PrimaryForegroundBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,3">
                                                <Run Text="{Binding MissionType}"/>
                                                <Run Text="{Binding LevelRange}"/>
                                                <Run Text="-"/>
                                                <Run Text="{Binding Faction}"/>
                                            </TextBlock>

                                            <TextBlock Grid.Row="2" Text="{Binding Location}" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="11" TextWrapping="Wrap"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
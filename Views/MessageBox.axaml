<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="framenion.MessageBox"
        xmlns:local="clr-namespace:framenion"
        x:DataType="local:MessageBox"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        MinWidth="200"
        MaxWidth="400"
        CanResize="False"
        Background="{DynamicResource SurfaceBackgroundBrush}">

    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Vertical" Margin="10,10,10,10">
            <TextBlock Text="{Binding Message}" Foreground="{DynamicResource PrimaryForegroundBrush}" TextWrapping="Wrap"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Name="Ok" Content="{Binding OkButtonText}" Click="Ok_Click" Margin="0,0,10,10"/>
            <Button Name="Cancel" Content="{Binding CancelButtonText}" IsVisible="{Binding ShowCancelButton}" Click="Cancel_Click" Margin="0,0,10,10"/>
        </StackPanel>
    </Grid>
</Window>